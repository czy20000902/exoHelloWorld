Bootstrap: docker
From: python:3.13-slim

%arguments
    VERSION=0.0.0

%files
    pyproject.toml /app/
    src/ /app/src/
    LICENSE /app/
    README.md /app/

%post
    cd /app
    pip install uv
    uv venv /opt/venv

    export SETUPTOOLS_SCM_PRETEND_VERSION="{{ VERSION }}"
    
    VIRTUAL_ENV=/opt/venv uv sync --active

%environment
    export PATH="/opt/venv/bin:$PATH"
    export UV_NO_SYNC=1
    export UV_FROZEN=1

%runscript
    @ navigate to the bound code directory first
    cd /app
    # Act as a universal 'uv' engine. 
    # The "$@" passes any scripts or arguments from the terminal directly into the frozen environment.
    exec uv run "$@"